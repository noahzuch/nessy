#!/usr/bin/env bash
# Claude Code's plugin installer does not run `npm link` or `npm install -g`,
# so the `bin` field in package.json is never wired into PATH. Instead, Claude
# Code adds the plugin's `bin/` directory to the Bash tool's PATH when the
# plugin is active. This wrapper is that entry point.
exec node "${CLAUDE_PLUGIN_ROOT}/dist/cli/main.js" "$@"
