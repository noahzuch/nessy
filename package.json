{
  "name": "nessy",
  "version": "0.1.0",
  "description": "Claude Code plugin: read-before-write enforcement (Plan 1 skeleton)",
  "type": "module",
  "bin": {
    "nessy": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "postbuild": "node --input-type=commonjs -e \"const{readFileSync,writeFileSync}=require('fs'),f='dist/cli/main.js';writeFileSync(f,'#!/usr/bin/env node\\n'+readFileSync(f,'utf8'))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prettier": "^3.8.4",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "ignore": "^5.3.2",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
